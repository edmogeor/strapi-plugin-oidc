{
  "name": "strapi-plugin-oidc",
  "version": "1.0.8",
  "description": "OIDC plugin for Strapi!",
  "strapi": {
    "displayName": "OIDC Plugin",
    "name": "strapi-plugin-oidc",
    "description": "Provides OIDC middleware for Strapi instances",
    "kind": "plugin"
  },
  "scripts": {
    "build": "strapi-plugin build",
    "watch": "strapi-plugin watch",
    "watch:link": "strapi-plugin watch:link",
    "verify": "strapi-plugin verify",
    "test": "vitest run",
    "lint": "eslint"
  },
  "keywords": [
    "strapi",
    "plugin",
    "oauth",
    "OIDC",
    "Zitadel"
  ],
  "peerDependencies": {
    "@strapi/strapi": "^5.24.1"
  },
  "dependencies": {
    "@strapi/design-system": "^2.2.0",
    "@strapi/icons": "^2.2.0",
    "@strapi/utils": "^5.41.1",
    "axios": "^1.14.0",
    "generate-password": "^1.7.1",
    "pkce-challenge": "^6.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-intl": "^6.8.9",
    "react-router-dom": "^6.30.3",
    "styled-components": "^6.3.12"
  },
  "author": {
    "name": "edmogeor",
    "url": "https://github.com/edmogeor/strapi-plugin-oidc"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/edmogeor/strapi-plugin-oidc"
  },
  "bugs": {
    "url": "https://github.com/edmogeor/strapi-plugin-oidc/issues"
  },
  "maintainers": [
    {
      "name": "edmogeor"
    }
  ],
  "engines": {
    "node": ">=20.0.0 <=24.x.x",
    "npm": ">=6.0.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT",
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@strapi/sdk-plugin": "^6.0.1",
    "@strapi/typescript-utils": "^5.41.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "exports": {
    "./package.json": "./package.json",
    "./strapi-admin": {
      "source": "./admin/src/index.js",
      "import": "./dist/admin/index.mjs",
      "require": "./dist/admin/index.js",
      "default": "./dist/admin/index.js"
    },
    "./strapi-server": {
      "source": "./server/index.js",
      "import": "./dist/server/index.mjs",
      "require": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    }
  }
}
